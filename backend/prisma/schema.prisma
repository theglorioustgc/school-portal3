// ==========================================================
// FOUNDATION SCHEMA
// Every other module (attendance, grades, fees...)
// will add its own tables that reference these by ID.
// ==========================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Supabase Postgres connection string goes in .env
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------
// SCHOOL CONFIG — one row per school instance.
// ----------------------------------------------------------
model SchoolConfig {
  id            String   @id @default(uuid())
  schoolCode    String   @unique
  schoolName    String
  logoUrl       String?
  primaryColor  String   @default("#1E3A8A")
  secondaryColor String  @default("#F59E0B")
  contactEmail  String?
  contactPhone  String?
  currentTerm   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ----------------------------------------------------------
// ID COUNTERS
// ----------------------------------------------------------
model IdCounter {
  id          String @id @default(uuid())
  idType      String
  year        Int
  lastNumber  Int    @default(0)

  @@unique([idType, year])
}

// ----------------------------------------------------------
// ROLES
// ----------------------------------------------------------
model Student {
  id              String   @id @default(uuid())
  studentId       String   @unique
  firstName       String
  lastName        String
  admissionYear   Int
  classId         String?
  class           SchoolClass? @relation(fields: [classId], references: [id])
  status          String   @default("active")
  leftDate        DateTime?
  leftReason      String?
  parentEmail     String?
  parentPhone     String?
  passwordHash    String
  mustChangePassword Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attendanceRecords AttendanceRecord[]
}

model Teacher {
  id              String   @id @default(uuid())
  teacherId       String   @unique
  firstName       String
  lastName        String
  joinYear        Int
  email           String?
  phone           String?
  passwordHash    String
  mustChangePassword Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignments       TeacherAssignment[]
  timetableEntries  TimetableEntry[]
  attendanceMarked  AttendanceRecord[]
}

model AdminUser {
  id              String   @id @default(uuid())
  email           String   @unique
  firstName       String
  lastName        String
  role            String   @default("admin")
  passwordHash    String
  createdAt       DateTime @default(now())
}

model BursarUser {
  id              String   @id @default(uuid())
  email           String   @unique
  firstName       String
  lastName        String
  passwordHash    String
  createdAt       DateTime @default(now())
}

// ----------------------------------------------------------
// CLASSES & SUBJECTS
// ----------------------------------------------------------
model SchoolClass {
  id          String   @id @default(uuid())
  name        String   @unique
  students    Student[]
  assignments TeacherAssignment[]
  timetableEntries TimetableEntry[]
  attendanceRecords AttendanceRecord[]
}

model Subject {
  id          String   @id @default(uuid())
  name        String   @unique
  assignments TeacherAssignment[]
  timetableEntries TimetableEntry[]
}

// ----------------------------------------------------------
// TEACHER ASSIGNMENT — the gatekeeper table.
// ----------------------------------------------------------
model TeacherAssignment {
  id          String   @id @default(uuid())
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  classId     String
  class       SchoolClass @relation(fields: [classId], references: [id])
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, classId, subjectId])
}

// ----------------------------------------------------------
// TIMETABLE
// ----------------------------------------------------------
model TimetableEntry {
  id          String   @id @default(uuid())
  classId     String
  class       SchoolClass @relation(fields: [classId], references: [id])
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  dayOfWeek   String
  periodNumber Int
  createdAt   DateTime @default(now())

  @@unique([classId, dayOfWeek, periodNumber])
}

// ----------------------------------------------------------
// ATTENDANCE — one row per student, per class, per day.
// Marked by whichever teacher is assigned to that class
// (any subject), or by an admin. Enforced in route logic.
// ----------------------------------------------------------
model AttendanceRecord {
  id            String   @id @default(uuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  classId       String
  class         SchoolClass @relation(fields: [classId], references: [id])
  date          DateTime @db.Date
  status        String   // "present" | "absent" | "late"
  markedById    String?
  markedBy      Teacher? @relation(fields: [markedById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([studentId, date])
}
