// ==========================================================
// FOUNDATION SCHEMA
// Every other module (fees, documents...) will add its own
// tables that reference these by ID.
// ==========================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SchoolConfig {
  id            String   @id @default(uuid())
  schoolCode    String   @unique
  schoolName    String
  logoUrl       String?
  primaryColor  String   @default("#1E3A8A")
  secondaryColor String  @default("#F59E0B")
  contactEmail  String?
  contactPhone  String?
  currentTerm   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model IdCounter {
  id          String @id @default(uuid())
  idType      String
  year        Int
  lastNumber  Int    @default(0)

  @@unique([idType, year])
}

model Student {
  id              String   @id @default(uuid())
  studentId       String   @unique
  firstName       String
  lastName        String
  admissionYear   Int
  classId         String?
  class           SchoolClass? @relation(fields: [classId], references: [id])
  status          String   @default("active")
  leftDate        DateTime?
  leftReason      String?
  parentEmail     String?
  parentPhone     String?
  passwordHash    String
  mustChangePassword Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attendanceRecords AttendanceRecord[]
  gradeRecords      GradeRecord[]
}

model Teacher {
  id              String   @id @default(uuid())
  teacherId       String   @unique
  firstName       String
  lastName        String
  joinYear        Int
  email           String?
  phone           String?
  passwordHash    String
  mustChangePassword Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignments       TeacherAssignment[]
  timetableEntries  TimetableEntry[]
  attendanceMarked  AttendanceRecord[]
  gradesEntered     GradeRecord[]
  announcements     Announcement[]
}

model AdminUser {
  id              String   @id @default(uuid())
  email           String   @unique
  firstName       String
  lastName        String
  role            String   @default("admin")
  passwordHash    String
  createdAt       DateTime @default(now())

  announcements   Announcement[]
}

model BursarUser {
  id              String   @id @default(uuid())
  email           String   @unique
  firstName       String
  lastName        String
  passwordHash    String
  createdAt       DateTime @default(now())
}

model SchoolClass {
  id          String   @id @default(uuid())
  name        String   @unique
  students    Student[]
  assignments TeacherAssignment[]
  timetableEntries TimetableEntry[]
  attendanceRecords AttendanceRecord[]
  gradeRecords GradeRecord[]
  announcements Announcement[]
}

model Subject {
  id          String   @id @default(uuid())
  name        String   @unique
  assignments TeacherAssignment[]
  timetableEntries TimetableEntry[]
  gradeRecords GradeRecord[]
}

model TeacherAssignment {
  id          String   @id @default(uuid())
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  classId     String
  class       SchoolClass @relation(fields: [classId], references: [id])
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, classId, subjectId])
}

model TimetableEntry {
  id          String   @id @default(uuid())
  classId     String
  class       SchoolClass @relation(fields: [classId], references: [id])
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  dayOfWeek   String
  periodNumber Int
  createdAt   DateTime @default(now())

  @@unique([classId, dayOfWeek, periodNumber])
}

model AttendanceRecord {
  id            String   @id @default(uuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  classId       String
  class         SchoolClass @relation(fields: [classId], references: [id])
  date          DateTime @db.Date
  status        String
  markedById    String?
  markedBy      Teacher? @relation(fields: [markedById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([studentId, date])
}

model GradeRecord {
  id            String   @id @default(uuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  classId       String
  class         SchoolClass @relation(fields: [classId], references: [id])
  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id])
  term          String
  ca1           Float?
  ca2           Float?
  ca3           Float?
  exam          Float?
  total         Float?
  status        String   @default("draft")
  enteredById   String?
  enteredBy     Teacher? @relation(fields: [enteredById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([studentId, subjectId, term])
}

// ----------------------------------------------------------
// ANNOUNCEMENTS — audience-scoped: "all" | "teachers" | "students" | "class"
// Admin can post to any audience. Teachers can only post to
// "class" audience, and only for a class they're assigned to
// (checked in route logic, same pattern as attendance/gradebook).
// createdByAdminId / createdByTeacherId: exactly one is set,
// depending on who posted it.
// ----------------------------------------------------------
model Announcement {
  id                  String   @id @default(uuid())
  title               String
  body                String
  audience            String   // "all" | "teachers" | "students" | "class"
  classId             String?
  class               SchoolClass? @relation(fields: [classId], references: [id])
  createdByAdminId    String?
  createdByAdmin      AdminUser? @relation(fields: [createdByAdminId], references: [id])
  createdByTeacherId  String?
  createdByTeacher    Teacher? @relation(fields: [createdByTeacherId], references: [id])
  createdAt           DateTime @default(now())
}
