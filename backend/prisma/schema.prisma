// ==========================================================
// FOUNDATION SCHEMA
// ==========================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SchoolConfig {
  id            String   @id @default(uuid())
  schoolCode    String   @unique
  schoolName    String
  logoUrl       String?
  primaryColor  String   @default("#1E3A8A")
  secondaryColor String  @default("#F59E0B")
  contactEmail  String?
  contactPhone  String?
  currentTerm   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model IdCounter {
  id          String @id @default(uuid())
  idType      String
  year        Int
  lastNumber  Int    @default(0)

  @@unique([idType, year])
}

model Student {
  id              String   @id @default(uuid())
  studentId       String   @unique
  firstName       String
  lastName        String
  admissionYear   Int
  classId         String?
  class           SchoolClass? @relation(fields: [classId], references: [id])
  status          String   @default("active")
  leftDate        DateTime?
  leftReason      String?
  parentEmail     String?
  parentPhone     String?
  passwordHash    String
  mustChangePassword Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attendanceRecords AttendanceRecord[]
  gradeRecords      GradeRecord[]
  submissions       AssignmentSubmission[]
}

model Teacher {
  id              String   @id @default(uuid())
  teacherId       String   @unique
  firstName       String
  lastName        String
  joinYear        Int
  email           String?
  phone           String?
  passwordHash    String
  mustChangePassword Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignments       TeacherAssignment[]
  timetableEntries  TimetableEntry[]
  attendanceMarked  AttendanceRecord[]
  gradesEntered     GradeRecord[]
  announcements     Announcement[]
  assignmentsPosted Assignment[]
  eventsCreated     Event[]
}

model AdminUser {
  id              String   @id @default(uuid())
  email           String   @unique
  firstName       String
  lastName        String
  role            String   @default("admin")
  passwordHash    String
  createdAt       DateTime @default(now())

  announcements   Announcement[]
  eventsCreated   Event[]
}

model BursarUser {
  id              String   @id @default(uuid())
  email           String   @unique
  firstName       String
  lastName        String
  passwordHash    String
  createdAt       DateTime @default(now())
}

model SchoolClass {
  id          String   @id @default(uuid())
  name        String   @unique
  students    Student[]
  assignments TeacherAssignment[]
  timetableEntries TimetableEntry[]
  attendanceRecords AttendanceRecord[]
  gradeRecords GradeRecord[]
  announcements Announcement[]
  classAssignments Assignment[]
}

model Subject {
  id          String   @id @default(uuid())
  name        String   @unique
  assignments TeacherAssignment[]
  timetableEntries TimetableEntry[]
  gradeRecords GradeRecord[]
  classAssignments Assignment[]
}

model TeacherAssignment {
  id          String   @id @default(uuid())
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  classId     String
  class       SchoolClass @relation(fields: [classId], references: [id])
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, classId, subjectId])
}

model TimetableEntry {
  id          String   @id @default(uuid())
  classId     String
  class       SchoolClass @relation(fields: [classId], references: [id])
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  dayOfWeek   String
  periodNumber Int
  createdAt   DateTime @default(now())

  @@unique([classId, dayOfWeek, periodNumber])
}

model AttendanceRecord {
  id            String   @id @default(uuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  classId       String
  class         SchoolClass @relation(fields: [classId], references: [id])
  date          DateTime @db.Date
  status        String
  markedById    String?
  markedBy      Teacher? @relation(fields: [markedById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([studentId, date])
}

model GradeRecord {
  id            String   @id @default(uuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  classId       String
  class         SchoolClass @relation(fields: [classId], references: [id])
  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id])
  term          String
  ca1           Float?
  ca2           Float?
  ca3           Float?
  exam          Float?
  total         Float?
  status        String   @default("draft")
  enteredById   String?
  enteredBy     Teacher? @relation(fields: [enteredById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([studentId, subjectId, term])
}

model Announcement {
  id                  String   @id @default(uuid())
  title               String
  body                String
  audience            String
  classId             String?
  class               SchoolClass? @relation(fields: [classId], references: [id])
  createdByAdminId    String?
  createdByAdmin      AdminUser? @relation(fields: [createdByAdminId], references: [id])
  createdByTeacherId  String?
  createdByTeacher    Teacher? @relation(fields: [createdByTeacherId], references: [id])
  createdAt           DateTime @default(now())
}

model Assignment {
  id            String   @id @default(uuid())
  title         String
  description   String
  linkUrl       String?
  dueDate       DateTime
  classId       String
  class         SchoolClass @relation(fields: [classId], references: [id])
  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id])
  postedById    String
  postedBy      Teacher  @relation(fields: [postedById], references: [id])
  createdAt     DateTime @default(now())

  submissions   AssignmentSubmission[]
}

model AssignmentSubmission {
  id            String   @id @default(uuid())
  assignmentId  String
  assignment    Assignment @relation(fields: [assignmentId], references: [id])
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  linkUrl       String
  submittedAt   DateTime @default(now())

  @@unique([assignmentId, studentId])
}

// ----------------------------------------------------------
// EVENTS — school calendar. Audience-scoped like announcements
// (all/teachers/students/class). reminderSent tracks whether
// the day-before reminder alert has already gone out, so a
// scheduled job doesn't send it twice.
// ----------------------------------------------------------
model Event {
  id                String   @id @default(uuid())
  title             String
  description       String?
  eventDate         DateTime
  audience          String   // "all" | "teachers" | "students" | "class"
  classId           String?
  createdByAdminId  String?
  createdByAdmin    AdminUser? @relation(fields: [createdByAdminId], references: [id])
  createdByTeacherId String?
  createdByTeacher  Teacher? @relation(fields: [createdByTeacherId], references: [id])
  reminderSent      Boolean  @default(false)
  createdAt         DateTime @default(now())
}

// ----------------------------------------------------------
// ALERT LOG — every notification the system has sent, for
// admin visibility/audit. Not the notification itself (that's
// utils/notify.js) — just a record that one went out.
// ----------------------------------------------------------
model AlertLog {
  id          String   @id @default(uuid())
  recipient   String   // email or phone the alert was sent to
  channel     String   // "email" | "sms"
  message     String
  triggerType String   // "attendance_absent" | "grade_published" | "fee_status" | "announcement" | "event_reminder"
  sentAt      DateTime @default(now())
}
