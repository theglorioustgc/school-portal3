// ==========================================================
// FOUNDATION SCHEMA
// ==========================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SchoolConfig {
  id            String   @id @default(uuid())
  schoolCode    String   @unique
  schoolName    String
  logoUrl       String?
  primaryColor  String   @default("#1E3A8A")
  secondaryColor String  @default("#F59E0B")
  contactEmail  String?
  contactPhone  String?
  currentTerm   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model IdCounter {
  id          String @id @default(uuid())
  idType      String
  year        Int
  lastNumber  Int    @default(0)

  @@unique([idType, year])
}

model Student {
  id              String   @id @default(uuid())
  studentId       String   @unique
  firstName       String
  lastName        String
  admissionYear   Int
  classId         String?
  class           SchoolClass? @relation(fields: [classId], references: [id])
  status          String   @default("active")
  leftDate        DateTime?
  leftReason      String?
  parentEmail     String?
  parentPhone     String?
  passwordHash    String
  mustChangePassword Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attendanceRecords AttendanceRecord[]
  gradeRecords      GradeRecord[]
  submissions       AssignmentSubmission[]
  feePayments       StudentFeePayment[]
  examScripts       ExamScript[]
  resultPublications ResultPublication[]
}

model Teacher {
  id              String   @id @default(uuid())
  teacherId       String   @unique
  firstName       String
  lastName        String
  joinYear        Int
  email           String?
  phone           String?
  passwordHash    String
  mustChangePassword Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignments       TeacherAssignment[]
  timetableEntries  TimetableEntry[]
  attendanceMarked  AttendanceRecord[]
  gradesEntered     GradeRecord[]
  announcements     Announcement[]
  assignmentsPosted Assignment[]
  eventsCreated     Event[]
  examScriptsMarked ExamScript[]
}

model AdminUser {
  id              String   @id @default(uuid())
  email           String   @unique
  firstName       String
  lastName        String
  role            String   @default("admin")
  passwordHash    String
  createdAt       DateTime @default(now())

  announcements   Announcement[]
  eventsCreated   Event[]
  feePaymentsMarked StudentFeePayment[]
}

model BursarUser {
  id              String   @id @default(uuid())
  email           String   @unique
  firstName       String
  lastName        String
  passwordHash    String
  createdAt       DateTime @default(now())

  feePaymentsMarked StudentFeePayment[]
}

model SchoolClass {
  id          String   @id @default(uuid())
  name        String   @unique
  students    Student[]
  assignments TeacherAssignment[]
  timetableEntries TimetableEntry[]
  attendanceRecords AttendanceRecord[]
  gradeRecords GradeRecord[]
  announcements Announcement[]
  classAssignments Assignment[]
  answerKeys  ExamAnswerKey[]
  examScripts ExamScript[]
}

model Subject {
  id          String   @id @default(uuid())
  name        String   @unique
  assignments TeacherAssignment[]
  timetableEntries TimetableEntry[]
  gradeRecords GradeRecord[]
  classAssignments Assignment[]
  answerKeys  ExamAnswerKey[]
  examScripts ExamScript[]
}

model TeacherAssignment {
  id          String   @id @default(uuid())
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  classId     String
  class       SchoolClass @relation(fields: [classId], references: [id])
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, classId, subjectId])
}

model TimetableEntry {
  id          String   @id @default(uuid())
  classId     String
  class       SchoolClass @relation(fields: [classId], references: [id])
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  dayOfWeek   String
  periodNumber Int
  createdAt   DateTime @default(now())

  @@unique([classId, dayOfWeek, periodNumber])
}

model AttendanceRecord {
  id            String   @id @default(uuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  classId       String
  class         SchoolClass @relation(fields: [classId], references: [id])
  date          DateTime @db.Date
  status        String
  markedById    String?
  markedBy      Teacher? @relation(fields: [markedById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([studentId, date])
}

model GradeRecord {
  id            String   @id @default(uuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  classId       String
  class         SchoolClass @relation(fields: [classId], references: [id])
  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id])
  term          String
  ca1           Float?
  ca2           Float?
  ca3           Float?
  exam          Float?
  total         Float?
  status        String   @default("draft")
  enteredById   String?
  enteredBy     Teacher? @relation(fields: [enteredById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([studentId, subjectId, term])
}

model Announcement {
  id                  String   @id @default(uuid())
  title               String
  body                String
  audience            String
  classId             String?
  class               SchoolClass? @relation(fields: [classId], references: [id])
  createdByAdminId    String?
  createdByAdmin      AdminUser? @relation(fields: [createdByAdminId], references: [id])
  createdByTeacherId  String?
  createdByTeacher    Teacher? @relation(fields: [createdByTeacherId], references: [id])
  createdAt           DateTime @default(now())
}

model Assignment {
  id            String   @id @default(uuid())
  title         String
  description   String
  linkUrl       String?
  dueDate       DateTime
  classId       String
  class         SchoolClass @relation(fields: [classId], references: [id])
  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id])
  postedById    String
  postedBy      Teacher  @relation(fields: [postedById], references: [id])
  createdAt     DateTime @default(now())

  submissions   AssignmentSubmission[]
}

model AssignmentSubmission {
  id            String   @id @default(uuid())
  assignmentId  String
  assignment    Assignment @relation(fields: [assignmentId], references: [id])
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  linkUrl       String
  submittedAt   DateTime @default(now())

  @@unique([assignmentId, studentId])
}

model Event {
  id                String   @id @default(uuid())
  title             String
  description       String?
  eventDate         DateTime
  audience          String
  classId           String?
  createdByAdminId  String?
  createdByAdmin    AdminUser? @relation(fields: [createdByAdminId], references: [id])
  createdByTeacherId String?
  createdByTeacher  Teacher? @relation(fields: [createdByTeacherId], references: [id])
  reminderSent      Boolean  @default(false)
  createdAt         DateTime @default(now())
}

model AlertLog {
  id          String   @id @default(uuid())
  recipient   String
  channel     String
  message     String
  triggerType String
  sentAt      DateTime @default(now())
}

model FeeType {
  id          String   @id @default(uuid())
  name        String
  amount      Float?
  term        String?
  createdAt   DateTime @default(now())

  payments    StudentFeePayment[]
}

model StudentFeePayment {
  id              String   @id @default(uuid())
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id])
  feeTypeId       String
  feeType         FeeType  @relation(fields: [feeTypeId], references: [id])
  status          String   @default("pending")
  markedPaidByAdminId   String?
  markedPaidByAdmin     AdminUser? @relation(fields: [markedPaidByAdminId], references: [id])
  markedPaidByBursarId  String?
  markedPaidByBursar    BursarUser? @relation(fields: [markedPaidByBursarId], references: [id])
  markedPaidAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([studentId, feeTypeId])
}

// ----------------------------------------------------------
// EXAMS
// ----------------------------------------------------------

// One answer key per class+subject+term. "answers" is a JSON
// string like ["A","C","B","D",...] — index 0 = question 1.
model ExamAnswerKey {
  id             String   @id @default(uuid())
  classId        String
  class          SchoolClass @relation(fields: [classId], references: [id])
  subjectId      String
  subject        Subject  @relation(fields: [subjectId], references: [id])
  term           String
  answers        String   // JSON array of correct options
  totalQuestions Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([classId, subjectId, term])
}

// One script per student, per subject, per term.
// objectiveAnswers is a JSON array of what the student selected,
// same index order as the answer key.
model ExamScript {
  id                String   @id @default(uuid())
  studentId         String
  student           Student  @relation(fields: [studentId], references: [id])
  classId           String
  class             SchoolClass @relation(fields: [classId], references: [id])
  subjectId         String
  subject           Subject  @relation(fields: [subjectId], references: [id])
  term              String
  objectiveAnswers  String?
  objectiveScore    Float?
  theoryScore       Float?
  totalScore        Float?
  status            String   @default("draft") // draft | submitted
  enteredById       String?
  enteredBy         Teacher? @relation(fields: [enteredById], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([studentId, subjectId, term])
}

// One row per student, per term — the compiled, ranked result.
// status stays "pending" until the principal explicitly publishes it.
model ResultPublication {
  id                  String   @id @default(uuid())
  studentId           String
  student             Student  @relation(fields: [studentId], references: [id])
  term                String
  totalScore          Float?
  average             Float?
  position            Int?
  subjectsExpected    Int?
  subjectsSubmitted   Int?
  status              String   @default("pending") // pending | published
  publishedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([studentId, term])
}
